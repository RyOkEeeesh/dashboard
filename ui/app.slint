import "./fonts/NotoSansJP-Regular.ttf";
import "./fonts/NotoSansJP-Bold.ttf";

enum WifiStatus {
    Add,
    Bad,
    Off,
    Excellent,
    Good,
    Fair,
    Poor
}

enum ClrThemeType {
    Slate,
    Gray, 
    Zinc, 
    Neutral,
    Stone,
    Taupe,
    Mauve,
    Mist,
    Olive
}

struct ClrProps {
    main_bg: color,
    sub_bg: color,
    app_bg: color,
    main_txt: color,
    app_txt: color,
}

export global Theme {
    out property <physical-length> display_width: 1920phx;
    out property <physical-length> display_height: 720phx;
    out property <physical-length> font_size: 24phx;
    out property <physical-length> grid_spacing: font_size * 1.5;
    out property <physical-length> app_size: (display_height - grid_spacing * 3) / 2;

    in-out property <bool> is_light: false;
    in-out property <ClrThemeType> clr_theme: ClrThemeType.Olive;

    pure function get_active_props(t: ClrThemeType) -> ClrProps {
        if (t == ClrThemeType.Slate) {
            return slate;
        }
        if (t == ClrThemeType.Gray) {
            return gray;
        }
        if (t == ClrThemeType.Zinc) {
            return zinc;
        }
        if (t == ClrThemeType.Neutral) {
            return neutral;
        }
        if (t == ClrThemeType.Stone) {
            return stone;
        }
        if (t == ClrThemeType.Taupe) {
            return taupe;
        }
        if (t == ClrThemeType.Mauve) {
            return mauve;
        }
        if (t == ClrThemeType.Mist) {
            return mist;
        }
        return olive;
    }

    out property <ClrProps> active: get_active_props(clr_theme);

    out property <ClrProps> slate: {
        main_bg: is_light ? #cbd5e1 : #1e293b,
        sub_bg: is_light ? #94a3b8 : #334155,
        app_bg: is_light ? #64748b : #475569,
        main_txt: is_light ? #1e293b : #e2e8f0,
        app_txt: is_light ? #e2e8f0 : #cbd5e1,
    };
    out property <ClrProps> gray: {
        main_bg: is_light ? #d1d5db : #1f2937,
        sub_bg: is_light ? #9ca3af : #374151,
        app_bg: is_light ? #6b7280 : #4b5563,
        main_txt: is_light ? #1f2937 : #e5e7eb,
        app_txt: is_light ? #e5e7eb : #d1d5db,
    };
    out property <ClrProps> zinc: {
        main_bg: is_light ? #d4d4d8 : #27272a,
        sub_bg: is_light ? #a1a1aa : #3f3f46,
        app_bg: is_light ? #71717a : #52525b,
        main_txt: is_light ? #374151 : #e4e4e7,
        app_txt: is_light ? #e4e4e7 : #d4d4d8,
    };
    out property <ClrProps> neutral: {
        main_bg: is_light ? #d4d4d4 : #262626,
        sub_bg: is_light ? #a3a3a3 : #404040,
        app_bg: is_light ? #737373 : #525252,
        main_txt: is_light ? #262626 : #e5e5e5,
        app_txt: is_light ? #e5e5e5 : #d4d4d4,
    };
    out property <ClrProps> stone: {
        main_bg: is_light ? #d6d3d1 : #292524,
        sub_bg: is_light ? #a8a29e : #44403c,
        app_bg: is_light ? #78716c : #57534e,
        main_txt: is_light ? #292524 : #e7e5e4,
        app_txt: is_light ? #e7e5e4 : #d6d3d1,
    };
    out property <ClrProps> taupe: {
        main_bg: is_light ? #d8d2d0 : #2b2422,
        sub_bg: is_light ? #aba09c : #473c39,
        app_bg: is_light ? #7c6d67 : #5b4f4b,
        main_txt: is_light ? #2b2422 : #e8e4e3,
        app_txt: is_light ? #e8e4e3 : #d8d2d0,
    };
    out property <ClrProps> mauve: {
        main_bg: is_light ? #d7d0d7 : #2a212c,
        sub_bg: is_light ? #a89ea9 : #463947,
        app_bg: is_light ? #79697b : #594c5b,
        main_txt: is_light ? #2a212c : #e7e4e7,
        app_txt: is_light ? #e7e4e7 : #d7d0d7,
    };
    out property <ClrProps> mist: {
        main_bg: is_light ? #d0d6d8 : #22292b,
        sub_bg: is_light ? #9ca8ab : #394447,
        app_bg: is_light ? #67787c : #4b585b,
        main_txt: is_light ? #22292b : #e3e7e8,
        app_txt: is_light ? #e3e7e8 : #d0d6d8,
    };
    out property <ClrProps> olive: {
        main_bg: is_light ? #d8d8d0 : #2b2b22,
        sub_bg: is_light ? #abab9c : #474739,
        app_bg: is_light ? #7c7c67 : #5b5b4b,
        main_txt: is_light ? #2b2b22 : #e8e8e3,
        app_txt: is_light ? #e8e8e3 : #d8d8d0,
    };
}

struct DatetimeState {
    Y: string,
    M: string,
    D: string,
    h: string,
    m: string,
    s: string,
}

component DatetimeApp inherits Rectangle {
    in property <DatetimeState> datetime;

    horizontal-stretch: 1;
    height: 100%;

    Text {
        text: "\{root.datetime.Y}/\{root.datetime.M}/\{root.datetime.D} \{root.datetime.h}:\{root.datetime.m}:\{root.datetime.s}";
        font-size: 2rem;
        font-weight: 700;
        color: Theme.active.main-txt;
    }
}

export enum AppTypes {
    RoomTemp,
    Other,
}

struct AppData {
    app_type: AppTypes,
    slot: int,
}


struct SlotInfo {
    x: length,
    y: length,
}

struct WeatherDataUi {
    temp: string,
    humidity: string,
    pressure: string,
}

export global AppStates {
    in-out property <[AppData]> apps: [
        {
            app_type: AppTypes.RoomTemp,
            slot: 1,
        },
        {
            app_type: AppTypes.Other,
            slot: 2,
        },
    ];
    in property <bool> can_bme_use;
    in property <WeatherDataUi> bme_result;
}

component AppShell inherits Rectangle {
    width: Theme.app_size;
    height: Theme.app_size;
    border-radius: 1.5rem;
}

component AppBase inherits AppShell {
    in property <bool> is_open: false;
    background: Theme.active.app_bg;
}

component RoomTempApp inherits AppBase {
    if !AppStates.can_bme_use: Text {
        color: Theme.active.app_txt;
        text: "現在ご利用できません";
        font-size: 1.2rem;
    }

    if AppStates.can_bme_use: Text {
        text: "\{AppStates.bme_result.temp}℃";
    }
}

component App {
    in property <AppTypes> app_type;
    in property <SlotInfo> pos;

    if app_type == AppTypes.RoomTemp: RoomTempApp {
        x: pos.x;
        y: pos.y;
    }
    if app_type == AppTypes.Other: AppBase {
        x: pos.x;
        y: pos.y;
    }
}




component AppGrid inherits GridLayout {
    height: 100%;
    width: (Theme.app_size * 2 + Theme.grid_spacing * 3);
    padding: Theme.grid_spacing;
    spacing: Theme.grid_spacing;
    out property <[SlotInfo]> slots: [
        { x: s0.absolute-position.x, y: s0.absolute-position.y },
        { x: s1.absolute-position.x, y: s1.absolute-position.y },
        { x: s2.absolute-position.x, y: s2.absolute-position.y },
        { x: s3.absolute-position.x, y: s3.absolute-position.y },
    ];

    s0 := AppShell {
        col: 0;
        row: 0;
    }

    s1 := AppShell {
        col: 0;
        row: 1;
    }

    s2 := AppShell {
        col: 1;
        row: 0;
    }

    s3 := AppShell {
        col: 1;
        row: 1;
    }
}

component Home inherits Rectangle {
    clip: true;
    height: 100%;
    width: (Theme.app_size * 2 + Theme.grid_spacing * 3);

    property <int> current_page: 0;
    property <int> num_page: 1;

    sgr := SwipeGestureHandler {
        handle-swipe-right: current_page > 0;
        handle-swipe-left: current_page < num_page;
        swiped => {
            if self.current-position.x > self.pressed-position.x + self.width / 4 {
                current-page -= 1;
            } else if self.current-position.x < self.pressed-position.x - self.width / 4 {
                current-page += 1;
            }
        }

        HorizontalLayout {
            property <length> position: - current-page * root.width;
            animate position {
                duration: 200ms;
                easing: ease-in-out;
            }
            property <length> swipe-offset;
            x: position + swipe-offset;
            states [
                swiping when sgr.swiping: {
                    swipe-offset: sgr.current-position.x - sgr.pressed-position.x;
                    out {
                        animate swipe-offset {
                            duration: 200ms;
                            easing: ease-in-out;
                        }
                    }
                }
            ]

            grid := AppGrid { }

            for app in AppStates.apps: App {
                app_type: app.app_type;
                pos: grid.slots[app.slot];
            }
        }
    }
}

export component Main inherits Window {
    default-font-family: "Noto Sans JP";
    default-font-size: Theme.font_size;
    default-font-weight: 400;
    width: Theme.display_width;
    height: Theme.display_height;
    background: Theme.active.main_bg;

    in property <DatetimeState> datetime;
    in property <WifiStatus> wifi_status;

    HorizontalLayout {
        DatetimeApp {
            datetime: datetime;
        }

        Home { }

        Rectangle {
            width: 2rem;
            height: 100%;
            background: Theme.active.sub_bg;

            VerticalLayout {
                alignment: end;
                width: 100%;
                height: 100%;

                wifi_icon := Image {
                    source: @image-url("./icons/wifi-add.svg");
                    states [
                        wifi-add when wifi_status == WifiStatus.Add: {
                            source: @image-url("./icons/wifi-add.svg");
                        }
                        wifi-bad when wifi_status == WifiStatus.Bad: {
                            source: @image-url("./icons/wifi-bad.svg");
                        }
                        wifi-off when wifi_status == WifiStatus.Off: {
                            source: @image-url("./icons/wifi-off.svg");
                        }
                        wifi-excellent when wifi_status == WifiStatus.Excellent: {
                            source: @image-url("./icons/wifi-excellent.svg");
                        }
                        wifi-good when wifi_status == WifiStatus.Good: {
                            source: @image-url("./icons/wifi-good.svg");
                        }
                        wifi-fair when wifi_status == WifiStatus.Fair: {
                            source: @image-url("./icons/wifi-fair.svg");
                        }
                        wifi-poor when wifi_status == WifiStatus.Poor: {
                            source: @image-url("./icons/wifi-poor.svg");
                        }
                    ]
                }

                theme := Image {
                    states [
                        light when Theme.is_light: {
                            source: @image-url("./icons/light.svg");
                        }
                        dark when !Theme.is_light: {
                            source: @image-url("./icons/dark.svg");
                        }
                    ]
                    TouchArea {
                        clicked => {
                            Theme.is_light = !Theme.is_light;
                        }
                    }
                }

                setting := Image {
                    source: @image-url("./icons/setting.svg");
                }
            }
        }
    }
}
