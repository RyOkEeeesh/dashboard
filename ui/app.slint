import "./fonts/NotoSansJP-Regular.ttf";
import "./fonts/NotoSansJP-Bold.ttf";
import "./fonts/Inter-Regular.ttf";

enum WifiStatus {
    Add,
    Bad,
    Off,
    Excellent,
    Good,
    Fair,
    Poor
}

enum ClrThemeType {
    Slate,
    Gray, 
    Zinc, 
    Neutral,
    Stone,
    Taupe,
    Mauve,
    Mist,
    Olive
}

struct ClrProps {
    main_bg: color,
    sub_bg: color,
    app_bg: color,
    main_txt: color,
    app_txt: color,
}

export global Theme {
    out property <physical-length> display_width: 1920phx;
    out property <physical-length> display_height: 720phx;
    out property <physical-length> font_size: 24phx;
    out property <physical-length> grid_spacing: font_size * 1.5;
    out property <physical-length> app_size: (display_height - grid_spacing * 3) / 2;
    out property <physical-length> app_size_open: display_height - grid_spacing * 2;
    out property <physical-length> home_width: (Theme.app_size * 2 + Theme.grid_spacing * 3);

    in-out property <bool> is_light: false;
    in-out property <ClrThemeType> clr_theme: ClrThemeType.Neutral;

    pure function get_active_props(t: ClrThemeType) -> ClrProps {
        if (t == ClrThemeType.Slate) {
            return slate;
        }
        if (t == ClrThemeType.Gray) {
            return gray;
        }
        if (t == ClrThemeType.Zinc) {
            return zinc;
        }
        if (t == ClrThemeType.Neutral) {
            return neutral;
        }
        if (t == ClrThemeType.Stone) {
            return stone;
        }
        if (t == ClrThemeType.Taupe) {
            return taupe;
        }
        if (t == ClrThemeType.Mauve) {
            return mauve;
        }
        if (t == ClrThemeType.Mist) {
            return mist;
        }
        return olive;
    }

    out property <ClrProps> active: get_active_props(clr_theme);

    out property <ClrProps> slate: {
        main_bg: is_light ? #cbd5e1 : #1e293b,
        sub_bg: is_light ? #94a3b8 : #334155,
        app_bg: is_light ? #64748b : #475569,
        main_txt: is_light ? #1e293b : #e2e8f0,
        app_txt: is_light ? #e2e8f0 : #cbd5e1,
    };
    out property <ClrProps> gray: {
        main_bg: is_light ? #d1d5db : #1f2937,
        sub_bg: is_light ? #9ca3af : #374151,
        app_bg: is_light ? #6b7280 : #4b5563,
        main_txt: is_light ? #1f2937 : #e5e7eb,
        app_txt: is_light ? #e5e7eb : #d1d5db,
    };
    out property <ClrProps> zinc: {
        main_bg: is_light ? #d4d4d8 : #27272a,
        sub_bg: is_light ? #a1a1aa : #3f3f46,
        app_bg: is_light ? #71717a : #52525b,
        main_txt: is_light ? #374151 : #e4e4e7,
        app_txt: is_light ? #e4e4e7 : #d4d4d8,
    };
    out property <ClrProps> neutral: {
        main_bg: is_light ? #d4d4d4 : #262626,
        sub_bg: is_light ? #a3a3a3 : #404040,
        app_bg: is_light ? #737373 : #525252,
        main_txt: is_light ? #262626 : #e5e5e5,
        app_txt: is_light ? #e5e5e5 : #d4d4d4,
    };
    out property <ClrProps> stone: {
        main_bg: is_light ? #d6d3d1 : #292524,
        sub_bg: is_light ? #a8a29e : #44403c,
        app_bg: is_light ? #78716c : #57534e,
        main_txt: is_light ? #292524 : #e7e5e4,
        app_txt: is_light ? #e7e5e4 : #d6d3d1,
    };
    out property <ClrProps> taupe: {
        main_bg: is_light ? #d8d2d0 : #2b2422,
        sub_bg: is_light ? #aba09c : #473c39,
        app_bg: is_light ? #7c6d67 : #5b4f4b,
        main_txt: is_light ? #2b2422 : #e8e4e3,
        app_txt: is_light ? #e8e4e3 : #d8d2d0,
    };
    out property <ClrProps> mauve: {
        main_bg: is_light ? #d7d0d7 : #2a212c,
        sub_bg: is_light ? #a89ea9 : #463947,
        app_bg: is_light ? #79697b : #594c5b,
        main_txt: is_light ? #2a212c : #e7e4e7,
        app_txt: is_light ? #e7e4e7 : #d7d0d7,
    };
    out property <ClrProps> mist: {
        main_bg: is_light ? #d0d6d8 : #22292b,
        sub_bg: is_light ? #9ca8ab : #394447,
        app_bg: is_light ? #67787c : #4b585b,
        main_txt: is_light ? #22292b : #e3e7e8,
        app_txt: is_light ? #e3e7e8 : #d0d6d8,
    };
    out property <ClrProps> olive: {
        main_bg: is_light ? #d8d8d0 : #2b2b22,
        sub_bg: is_light ? #abab9c : #474739,
        app_bg: is_light ? #7c7c67 : #5b5b4b,
        main_txt: is_light ? #2b2b22 : #e8e8e3,
        app_txt: is_light ? #e8e8e3 : #d8d8d0,
    };
}

struct DatetimeState {
    h: string,
    m: string,
    s: string,
}

component DatetimeApp inherits Rectangle {
    in property <DatetimeState> datetime;

    horizontal-stretch: 1;
    height: 100%;

    VerticalLayout {
        alignment: center;

        HorizontalLayout {
            property <length> time_font_size: 8rem;
            property <length> sec_font_size: 5rem;
            property <length> sec_padding: 0.8rem;
            alignment: center;
            spacing: 0.5rem;

            Text {
                text: root.datetime.h;
                font-family: "Inter";
                font-weight: 400;
                font-size: time_font_size;
            }

            Text {
                text: ":";
                font-family: "Inter";
                font-weight: 400;
                font-size: time_font_size;
            }

            Text {
                text: root.datetime.m;
                font-family: "Inter";
                font-weight: 400;
                font-size: time_font_size;
            }

            VerticalLayout {
                width: sec_font_size * 0.6 * 2 + sec_padding;
                alignment: end;
                padding-left: sec_padding;
                padding-bottom: sec_padding;
                Text {
                    text: root.datetime.s;
                    font-family: "Inter";
                    font-weight: 400;
                    font-size: sec_font_size;
                }
            }
        }
    }
}

export enum AppTypes {
    None,
    RoomTemp,
    Other,
}

struct AppData {
    app_type: AppTypes,
    slot: int,
}

struct Position {
    x: length,
    y: length,
}

struct WeatherDataUi {
    temp: string,
    humidity: string,
    pressure: string,
}

export global AppStates {
    in-out property <[AppData]> apps: [
        {
            app_type: AppTypes.RoomTemp,
            slot: 3,
        },
        {
            app_type: AppTypes.Other,
            slot: 4,
        },
    ];
    in-out property <int> num_page: 1;
    in-out property <AppTypes> opne_app: AppTypes.None;
    in property <bool> can_bme_use;
    in property <WeatherDataUi> bme_result;
}

component AppBase inherits Rectangle {
    in property <AppTypes> app_type: AppTypes.Other;
    out property <bool> is_open: AppStates.opne_app == root.app_type;
    width: 100%;
    height: 100%;

    callback open_touch();

    TouchArea {
        visible: is_open || AppStates.opne_app == AppTypes.None;
        clicked => {
            if is_open {
                open_touch();
            } else {
                AppStates.opne_app = app_type;
            }
        }
    }
}

component RoomTempApp inherits AppBase {
    app_type: AppTypes.RoomTemp;

    open_touch => {
        debug("タッチされました");
    }

    if !AppStates.can_bme_use: Text {
        color: Theme.active.app_txt;
        text: "現在ご利用できません";
        font-size: 1.2rem;
    }

    if AppStates.can_bme_use: Text {
        text: "\{AppStates.bme_result.temp}℃";
    }
}

component App inherits Rectangle {
    in property <AppTypes> app_type;
    in property <int> slot;

    property <Position> pos: {
        x: floor(slot / 4) * Theme.home_width + Theme.grid_spacing + mod(slot, 2) * (Theme.app_size + Theme.grid_spacing),
        y: Theme.grid_spacing + floor(mod(slot, 4) / 2) * (Theme.app_size + Theme.grid_spacing),
    };
    property <Position> pos_open: {
        x: floor(slot / 4) * Theme.home_width + Theme.grid_spacing,
        y: Theme.grid_spacing,
    };
    property <bool> is_open: AppStates.opne_app == root.app_type;
    property <string> title: "アプリ";

    states [
        room-temp when app_type == AppTypes.RoomTemp: {
            title: "室温";
        }
    ]

    x: is_open ? pos_open.x : pos.x;
    y: is_open ? pos_open.y : pos.y;
    background: Theme.active.app_bg;
    width: is_open ? Theme.app_size_open : Theme.app_size;
    height: is_open ? Theme.app_size_open : Theme.app_size;
    border-radius: 1.5rem;
    clip: true;

    animate x, y, width, height {
        duration: 250ms;
        easing: ease-out-quart;
    }

    main := VerticalLayout {
        padding: is_open ? Theme.grid_spacing : 0;
        spacing: is_open ? 0.5rem : 0;

        header := Rectangle {
            visible: is_open;
            width: 100%;
            height: is_open ? 2rem : 0;

            Image {
                x: 0;
                y: 0;
                width: 2rem;
                height: 2rem;
                source: @image-url("./icons/back.svg");

                TouchArea {
                    clicked => {
                        AppStates.opne_app = AppTypes.None;
                    }
                }
            }

            Text {
                x: 0;
                y: 0;
                width: 100%;
                height: 100%;
                text: title;
                font-size: 1.5rem;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        container := Rectangle {
            vertical-stretch: 1;
            if app_type == AppTypes.RoomTemp: RoomTempApp { }
            if app_type == AppTypes.Other: AppBase { }
        }
    }
}

component Home inherits Rectangle {
    property <int> current_page: 0;
    clip: true;
    width: Theme.home_width;
    height: 100%;

    sgr := SwipeGestureHandler {
        handle-swipe-right: AppStates.opne_app == AppTypes.None;
        handle-swipe-left: AppStates.opne_app == AppTypes.None;
        swiped => {
            if (self.current-position.x > self.pressed-position.x + self.width / 4) && (root.current_page > 0) {
                current-page -= 1;
            } else if (self.current-position.x < self.pressed-position.x - self.width / 4) && (root.current_page < AppStates.num_page) {
                current-page += 1;
            }
        }

        Rectangle {
            property <length> position: - current-page * root.width;
            animate position {
                duration: 200ms;
                easing: ease-out-circ;
            }
            property <physical-length> max_left_offset: root.current_page * root.width;
            property <physical-length> max_right_offset: (AppStates.num_page - root.current_page) * root.width;
            property <physical-length> limit: root.width / 5;
            property <physical-length> delta_x: sgr.current-position.x - sgr.pressed-position.x;
            property <physical-length> over_delta: (delta_x > max_left_offset) ? (delta_x - max_left_offset) : (delta_x < -max_right_offset) ? (delta_x + max_right_offset) : 0px;
            property <physical-length> elastic_offset: limit * (over_delta / (Math.abs(over_delta) + limit * 2));
            property <physical-length> swipe-offset;

            width: Theme.home_width * (AppStates.num_page + 1);
            height: 100%;
            x: position + swipe-offset;
            states [
                swiping when sgr.swiping: {
                    swipe-offset: (delta_x > max_left_offset) ? (max_left_offset + elastic_offset) : (delta_x < -max_right_offset) ? (-max_right_offset + elastic_offset) : delta_x;
                    out {
                        animate swipe-offset {
                            duration: 200ms;
                            easing: ease-out-circ;
                        }
                    }
                }
            ]

            for app in AppStates.apps: App {
                app_type: app.app_type;
                slot: app.slot;
            }
        }
    }
}

export component Main inherits Window {
    default-font-family: "Noto Sans JP";
    default-font-size: Theme.font_size;
    default-font-weight: 400;
    width: Theme.display_width;
    height: Theme.display_height;
    background: Theme.active.main_bg;

    in property <DatetimeState> datetime;
    in property <WifiStatus> wifi_status;

    HorizontalLayout {
        DatetimeApp {
            datetime: datetime;
        }

        Home { }

        Rectangle {
            width: 2rem;
            height: 100%;
            background: Theme.active.sub_bg;

            VerticalLayout {
                alignment: end;
                width: 100%;
                height: 100%;

                wifi_icon := Image {
                    source: @image-url("./icons/wifi-add.svg");
                    states [
                        wifi-add when wifi_status == WifiStatus.Add: {
                            source: @image-url("./icons/wifi-add.svg");
                        }
                        wifi-bad when wifi_status == WifiStatus.Bad: {
                            source: @image-url("./icons/wifi-bad.svg");
                        }
                        wifi-off when wifi_status == WifiStatus.Off: {
                            source: @image-url("./icons/wifi-off.svg");
                        }
                        wifi-excellent when wifi_status == WifiStatus.Excellent: {
                            source: @image-url("./icons/wifi-excellent.svg");
                        }
                        wifi-good when wifi_status == WifiStatus.Good: {
                            source: @image-url("./icons/wifi-good.svg");
                        }
                        wifi-fair when wifi_status == WifiStatus.Fair: {
                            source: @image-url("./icons/wifi-fair.svg");
                        }
                        wifi-poor when wifi_status == WifiStatus.Poor: {
                            source: @image-url("./icons/wifi-poor.svg");
                        }
                    ]
                }

                theme := Image {
                    states [
                        light when Theme.is_light: {
                            source: @image-url("./icons/light.svg");
                        }
                        dark when !Theme.is_light: {
                            source: @image-url("./icons/dark.svg");
                        }
                    ]
                    TouchArea {
                        clicked => {
                            Theme.is_light = !Theme.is_light;
                        }
                    }
                }

                setting := Image {
                    source: @image-url("./icons/setting.svg");
                }
            }
        }
    }
}
