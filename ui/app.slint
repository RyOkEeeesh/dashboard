import "./fonts/NotoSansJP-Regular.ttf";
import "./fonts/NotoSansJP-Bold.ttf";
import { StandardButton } from "std-widgets.slint";

enum TileOpenStatus {
    Normal,
    Main,
    Sub,
}

enum WifiStatus {
    Add,
    Bad,
    Off,
    Excellent,
    Good,
    Fair,
    Poor
}

enum ClrThemeType {
    Slate,
    Gray, 
    Zinc, 
    Neutral,
    Stone,
    Taupe,
    Mauve,
    Mist,
    Olive
}

export struct ClrProps {
    main_bg: color,
    sub_bg: color,
    app_bg: color,
    main_txt: color,
    app_txt: color,
}

export global AppTheme {
    in-out property <bool> is_light: false;
    out property <physical-length> display_width: 1920phx;
    out property <physical-length> display_height: 720phx;
    out property <physical-length> font_size: 24phx;
    out property <physical-length> grid_spacing: font_size * 1.5;
    out property <physical-length> app_size: (display_height - grid_spacing * 3) / 2;
}

export global ClrTheme {
    in-out property <ClrThemeType> clr_theme: ClrThemeType.Taupe;

    pure function get_active_props(t: ClrThemeType) -> ClrProps {
        if (t == ClrThemeType.Slate) { return slate; }
        if (t == ClrThemeType.Gray) { return gray; }
        if (t == ClrThemeType.Zinc) { return zinc; }
        if (t == ClrThemeType.Neutral) { return neutral; }
        if (t == ClrThemeType.Stone) { return stone; }
        if (t == ClrThemeType.Taupe) { return taupe; }
        if (t == ClrThemeType.Mauve) { return mauve; }
        if (t == ClrThemeType.Mist) { return mist; }
        return olive;
    }

    out property <ClrProps> active: get_active_props(clr_theme);

    out property <ClrProps> slate: {
        main_bg: AppTheme.is_light ? #cbd5e1 : #1e293b,
        sub_bg: AppTheme.is_light ? #94a3b8 : #334155,
        app_bg: AppTheme.is_light ? #64748b : #475569,
        main_txt: AppTheme.is_light ? #1e293b : #e2e8f0,
        app_txt: AppTheme.is_light ? #e2e8f0 : #cbd5e1,
    };
    out property <ClrProps> gray: {
        main_bg: AppTheme.is_light ? #d1d5db : #1f2937,
        sub_bg: AppTheme.is_light ? #9ca3af : #374151,
        app_bg: AppTheme.is_light ? #6b7280 : #4b5563,
        main_txt: AppTheme.is_light ? #1f2937 : #e5e7eb,
        app_txt: AppTheme.is_light ? #e5e7eb : #d1d5db,
    };
    out property <ClrProps> zinc: {
        main_bg: AppTheme.is_light ? #d4d4d8 : #27272a,
        sub_bg: AppTheme.is_light ? #a1a1aa : #3f3f46,
        app_bg: AppTheme.is_light ? #71717a : #52525b,
        main_txt: AppTheme.is_light ? #374151 : #e4e4e7,
        app_txt: AppTheme.is_light ? #e4e4e7 : #d4d4d8,
    };
    out property <ClrProps> neutral: {
        main_bg: AppTheme.is_light ? #d4d4d4 : #262626,
        sub_bg: AppTheme.is_light ? #a3a3a3 : #404040,
        app_bg: AppTheme.is_light ? #737373 : #525252,
        main_txt: AppTheme.is_light ? #262626 : #e5e5e5,
        app_txt: AppTheme.is_light ? #e5e5e5 : #d4d4d4,
    };
    out property <ClrProps> stone: {
        main_bg: AppTheme.is_light ? #d6d3d1 : #292524,
        sub_bg: AppTheme.is_light ? #a8a29e : #44403c,
        app_bg: AppTheme.is_light ? #78716c : #57534e,
        main_txt: AppTheme.is_light ? #292524 : #e7e5e4,
        app_txt: AppTheme.is_light ? #e7e5e4 : #d6d3d1,
    };
    out property <ClrProps> taupe: {
        main_bg: AppTheme.is_light ? #d8d2d0 : #2b2422,
        sub_bg: AppTheme.is_light ? #aba09c : #473c39,
        app_bg: AppTheme.is_light ? #7c6d67 : #5b4f4b,
        main_txt: AppTheme.is_light ? #2b2422 : #e8e4e3,
        app_txt: AppTheme.is_light ? #e8e4e3 : #d8d2d0,
    };
    out property <ClrProps> mauve: {
        main_bg: AppTheme.is_light ? #d7d0d7 : #2a212c,
        sub_bg: AppTheme.is_light ? #a89ea9 : #463947,
        app_bg: AppTheme.is_light ? #79697b : #594c5b,
        main_txt: AppTheme.is_light ? #2a212c : #e7e4e7,
        app_txt: AppTheme.is_light ? #e7e4e7 : #d7d0d7,
    };
    out property <ClrProps> mist: {
        main_bg: AppTheme.is_light ? #d0d6d8 : #22292b,
        sub_bg: AppTheme.is_light ? #9ca8ab : #394447,
        app_bg: AppTheme.is_light ? #67787c : #4b585b,
        main_txt: AppTheme.is_light ? #22292b : #e3e7e8,
        app_txt: AppTheme.is_light ? #e3e7e8 : #d0d6d8,
    };
    out property <ClrProps> olive: {
        main_bg: AppTheme.is_light ? #d8d8d0 : #2b2b22,
        sub_bg: AppTheme.is_light ? #abab9c : #474739,
        app_bg: AppTheme.is_light ? #7c7c67 : #5b5b4b,
        main_txt: AppTheme.is_light ? #2b2b22 : #e8e8e3,
        app_txt: AppTheme.is_light ? #e8e8e3 : #d8d8d0,
    };
}

export global AppState {
    in-out property <int> name;
    property <TileOpenStatus> open_status: TileOpenStatus.Normal;
}

struct TileData {
    can_use: bool,
    is_open: bool,
}

component Tile inherits Rectangle {
    in property <TileData> current_data: { can_use: false, is_open: false };

    width: AppTheme.app_size;
    height: AppTheme.app_size;
    background: ClrTheme.active.app_bg;
    border-radius: 1.5rem;
}

struct WeatherDataUi {
    temp: string,
    humidity: string,
    pressure: string,
}

component RoomTempTile inherits Tile {
    in property <WeatherDataUi> weather_data;

    if !(root.current_data.can-use): Text {
        color: ClrTheme.active.app_txt;
        text: "現在ご利用できません";
        font-size: 1.2rem;
    }

    if (root.current_data.can-use): Text {
        text: "\{root.weather_data.temp}℃";
    }
}

struct DatetimeState {
    Y: string,
    M: string,
    D: string,
    h: string,
    m: string,
    s: string,
}

component DatetimeTile inherits Rectangle {
    in property <TileData> current_data;
    in property <DatetimeState> datetime;

    horizontal-stretch: 1;
    height: 100%;

    Text {
        text: "\{root.datetime.Y}/\{root.datetime.M}/\{root.datetime.D} \{root.datetime.h}:\{root.datetime.m}:\{root.datetime.s}";
        font-size: 2rem;
        font-weight: 700;
        color: ClrTheme.active.main-txt;
    }
}

export component App inherits Window {
    default-font-family: "Noto Sans JP";
    default-font-size: AppTheme.font_size;
    default-font-weight: 400;
    width: AppTheme.display_width;
    height: AppTheme.display_height;
    background: ClrTheme.active.main_bg;

    in property <DatetimeState> datetime;
    in property <bool> can_bme_use;
    in property <WeatherDataUi> bme_result;
    in property <WifiStatus> wifi_status;

    HorizontalLayout {
        DatetimeTile {
            datetime: datetime;
        }

        Rectangle {
            height: 100%;
            width: (AppTheme.app_size * 2 + AppTheme.grid_spacing * 3);

            GridLayout {
                height: 100%;
                width: 100%;
                spacing: AppTheme.grid_spacing;
                padding: AppTheme.grid_spacing;

                RoomTempTile {
                    current_data: { can_use: can_bme_use };
                    weather_data: bme_result;
                }

                Tile { }

                Tile {
                    row: 1;
                    col: 0;
                }

                Tile {
                    row: 1;
                    col: 1;
                }
            }
        }

        Rectangle {
            width: 2rem;
            height: 100%;
            background: ClrTheme.active.sub_bg;

            VerticalLayout {
                alignment: end;
                width: 100%;
                height: 100%;

                wifi_icon := Image {
                    source: @image-url("./icons/wifi-add.svg");
                    states [
                        wifi-add when wifi_status == WifiStatus.Add: {
                            source: @image-url("./icons/wifi-add.svg");
                        }
                        wifi-bad when wifi_status == WifiStatus.Bad: {
                            source: @image-url("./icons/wifi-bad.svg");
                        }
                        wifi-off when wifi_status == WifiStatus.Off: {
                            source: @image-url("./icons/wifi-off.svg");
                        }
                        wifi-excellent when wifi_status == WifiStatus.Excellent: {
                            source: @image-url("./icons/wifi-excellent.svg");
                        }
                        wifi-good when wifi_status == WifiStatus.Good: {
                            source: @image-url("./icons/wifi-good.svg");
                        }
                        wifi-fair when wifi_status == WifiStatus.Fair: {
                            source: @image-url("./icons/wifi-fair.svg");
                        }
                        wifi-poor when wifi_status == WifiStatus.Poor: {
                            source: @image-url("./icons/wifi-poor.svg");
                        }
                    ]
                }

                theme := Image {
                    states [
                        light when AppTheme.is_light: {
                            source: @image-url("./icons/light.svg");
                        }
                        dark when !AppTheme.is_light: {
                            source: @image-url("./icons/dark.svg");
                        }
                    ]
                    TouchArea {
                        clicked => { AppTheme.is_light = !AppTheme.is_light; }
                    }
                }

                setting := Image {
                    source: @image-url("./icons/setting.svg");
                }
            }
        }
    }
}
